# Copy this file to .env and fill in your key from https://kie.ai/api-key
KIE_API_KEY=your_api_key_here

# Optional: port for the local server (default 3000)
PORT=3000

# Optional: which network interface to listen on (default 127.0.0.1 = this PC
# only). Set HOST=0.0.0.0 to also allow other devices on your home network to
# reach the app at http://<this-pc-ip>:<PORT> (e.g. http://192.168.1.50:3000).
# WARNING: the app has no login and spends your kie.ai credits — only enable LAN
# access on a network you trust, and never expose it to the public internet.
# HOST=0.0.0.0

# Optional: require a password to use the app. Leave unset/blank for no login.
# When set, every page and API call requires signing in first (recommended if
# you enable LAN access above). Anyone with this password has full access.
# APP_PASSWORD=

# Optional: where generated videos and saved reference media are stored.
# Defaults to the app's own "video" and "images" folders. Set either to point
# somewhere else — an absolute path (e.g. D:\seedance\video or /mnt/media/video)
# or a path relative to the app folder. Per-project subfolders are created inside.
# VIDEO_DIR=
# IMAGES_DIR=
